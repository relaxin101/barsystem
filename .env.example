###################################
####### Flask Config
###################################
FLASK_SECRET_KEY=supersecret
FLASK_ALLOWED_HOSTS=*
FLASK_DEBUG=False


###################################
####### Datenbank config
###################################
DATABASE_ENGINE=postgresql
DATABASE_NAME=barliste
DATABASE_USERNAME=ergo
DATABASE_PASSWORD=bibamus
DATABASE_PORT=5432
DATABASE_HOST=db # In Docker compose definiert, nicht verändern

###################################
####### Admin-User
###################################
# Wird in die Datenbank eingepflegt, muss vor erstem Start stimmen
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
MINDEST_GUTHABEN=-50.0
RANKING_CONFIG_TTL_STUNDEN=12
HOTLIST_DAYS=14
SCHWAERZUNGS_TEXT=Du bist geschwärzt!


###################################
#######Aussendungs-Modul
###################################
# Konto und Templates müssen
# vorher bei Brevo angelegt sein
BREVO_SECRET=
BREVO_SENDER_MAIL=
BREVO_SENDER_NAME=
BREVO_TEMPLATE=

# Für das Auto-Aufbuchungs-Modul (IMAP, alle optional)
# Fehlt IMAP_HOST, IMAP_USER oder IMAP_PASSWORD, wird der Job übersprungen.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=kasse@example.com
IMAP_PASSWORD=

# Filterkriterien (optional): nur Mails von diesem Absender / mit diesem Betreff (Teilstring)
AUTO_BETREFF="Kontoeingang bei George"
AUTO_SENDER=noreply@sparkasse.at

# Reguläre Ausdrücke zum Extrahieren von Konto und Betrag aus dem Mail-Text:
#   AUTO_KONTO_REGEX → Regex für Mitglied-Namen oder -E-Mail
#   AUTO_KONTO_GROUP → Capture-Group-Nummer (default: 1)
#   AUTO_BETRAG_REGEX → Regex für den Betrag (z. B. "12,50" oder "12.50")
#   AUTO_BETRAG_GROUP → Capture-Group-Nummer (default: 1)
#
# Beispiel (Bankbenachrichtigung): "Überweisung von Max Mustermann, Betrag: 20,00 EUR"
#   AUTO_KONTO_REGEX=von ([A-Za-zÄÖÜäöüß ]+),
#   AUTO_BETRAG_REGEX=Betrag:\s*([\d.,]+)\s*EUR
AUTO_BETRAG_GROUP=1
AUTO_BETRAG_REGEX="^.*Sie haben soeben (.*) EUR auf Ihr Konto (\d*) erhalten\\..*$"
AUTO_KONTO_GROUP=4
AUTO_KONTO_REGEX="^.*Buchungstext:\\s*((Barschulden)|(BS))(.*)\\..*$"
